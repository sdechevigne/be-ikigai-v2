---
import Layout from "../layouts/Layout.astro";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import { getLangFromUrl } from "../i18n/utils";
import { quizContent, SLUG_TO_CODE } from "../data/quiz";
import type { ProfilSlug, ProfilCode } from "../data/quiz";
import { fourCirclesSvg } from "./quiz/fourCircles";

export interface Props {
  slug: ProfilSlug;
}

const { slug } = Astro.props;
const lang = getLangFromUrl(Astro.url) === "en" ? "en" : "fr";
const content = quizContent[lang];
const code = SLUG_TO_CODE[slug];
const profil = content.profils[code];
const ui = content.ui;

// Diagramme Ikigai dédié par profil (images FR avec labels intégrés).
// Le 2e fichier conserve la coquille "ideealiste" présente dans le dossier.
const CODE_TO_DIAGRAM: Record<ProfilCode, string> = {
  A: "/assets/img/quizz/ikigai_cage_doree.png",
  B: "/assets/img/quizz/ikigai_ideealiste_epuise.png",
  C: "/assets/img/quizz/ikigai_page_blanche.png",
  D: "/assets/img/quizz/ikigai_fragmente.png",
};
const diagramSrc = CODE_TO_DIAGRAM[code];

const quizPath = lang === "fr" ? "/quiz" : "/en/quiz";

// TODO viralité : produire 4 images OG par profil (1200×630) puis remplacer la
// ligne ci-dessous par `https://be-ikigai.com/assets/img/quiz/og-${slug}.png`.
// En attendant on garde le logo pour éviter un aperçu de partage cassé.
const ogImage = "https://be-ikigai.com/assets/img/logo_fullhd.png";

const pageTitle =
  lang === "fr"
    ? `${profil.nom} — « ${profil.tagline} » | Quiz Be-ikigai`
    : `${profil.nom} — "${profil.tagline}" | Be-ikigai quiz`;
const pageDesc = profil.miniPortrait;

const ctaLabel =
  lang === "fr" ? "Et toi, dans quel brouillard es-tu ?" : "And you, which fog are you in?";
const ctaButton = lang === "fr" ? "Faire le test (2 min)" : "Take the test (2 min)";

const fortsLabel = ui.strongCircles;
const faiblesLabel = ui.weakCircles;
---

<Layout
  title={pageTitle}
  description={pageDesc}
  lang={lang}
  image={ogImage}
  type="article"
>
  <Navbar lang={lang} transparent={false} />
  <main class="min-h-[70vh] pt-24 sm:pt-28 bg-gradient-to-b from-gris-doux/15 via-blanc-coton to-white">
    <div class="w-full max-w-2xl mx-auto px-4 py-12 sm:py-16 text-bleu-crepuscule text-center">
      <div class="text-5xl mb-2">{profil.emoji}</div>
      <h1
        class="font-comfortaa text-3xl sm:text-4xl font-bold mb-3"
        style={`color:${profil.accentColor}`}
      >
        {profil.nom}
      </h1>
      <p class="text-lg italic text-bleu-crepuscule/80 mb-6">« {profil.tagline} »</p>
      <p class="text-base text-bleu-crepuscule/90 mb-8 max-w-xl mx-auto">
        {profil.miniPortrait}
      </p>

      {lang === "fr" ? (
        <img
          src={diagramSrc}
          alt={`Diagramme Ikigai du profil ${profil.nom}`}
          width="1024"
          height="768"
          loading="eager"
          class="w-full max-w-md mx-auto h-auto mb-6"
        />
      ) : (
        <div class="flex justify-center mb-6" set:html={fourCirclesSvg(code, lang)} />
      )}
      <p class="text-base text-bleu-crepuscule/90 mb-8 max-w-xl mx-auto">{profil.reveal}</p>

      <div class="text-left max-w-md mx-auto mb-10 bg-beige-chaleureux/40 rounded-2xl p-5">
        {profil.forts.length > 0 && (
          <>
            <div class="mb-1 text-sm font-bold" style={`color:${profil.accentColor}`}>
              {fortsLabel}
            </div>
            <ul class="text-sm text-bleu-crepuscule/80 mb-4 list-disc list-inside">
              {profil.forts.map((c) => <li>{content.cercles[c]}</li>)}
            </ul>
          </>
        )}
        {profil.faibles.length > 0 && (
          <>
            <div class="mb-1 text-sm font-bold text-bleu-crepuscule/50">{faiblesLabel}</div>
            <ul class="text-sm text-bleu-crepuscule/60 list-disc list-inside">
              {profil.faibles.map((c) => <li>{content.cercles[c]}</li>)}
            </ul>
          </>
        )}
      </div>

      <div class="bg-white border-2 border-bleu-crepuscule/10 rounded-2xl p-6 shadow-sm max-w-md mx-auto">
        <h2 class="font-comfortaa text-xl font-bold mb-4">{ctaLabel}</h2>
        <a
          href={quizPath}
          class="inline-block font-comfortaa font-bold rounded-xl px-8 py-3 text-base bg-bleu-crepuscule text-white shadow hover:shadow-lg transition"
        >
          {ctaButton}
        </a>
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>

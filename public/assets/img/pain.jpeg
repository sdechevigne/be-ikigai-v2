    <!-- Section 5: L'Ikigai expliqué -->
    <section class="py-14 lg:py-32" style="background-color: #2c3e50;">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto">
                <div class="text-center fade-in mb-12">
                    <h2 class="text-3xl md:text-5xl font-comfortaa text-white mb-8 md:mb-16">
                        Découvrez le secret japonais du bonheur et de la longévité
                    </h2>
                </div>
                <div class="mb-16">
                    <!-- Philosophie pour une vie épanouie -->
                    <div class="fade-in bg-white/10 backdrop-blur-sm rounded-3xl p-8">
                        <div class="text-lg md:text-xl text-white/90 space-y-6 grid md:grid-cols-[1fr_auto] sm:grid-cols-[minmax(auto,1fr)_auto] items-center justify-items-center">

                            <p>
                                L'Ikigai, philosophie née sur <a class="text-dore-serein" target="_blank" href="https://www.nationalgeographic.fr/voyage/bien-veillir-zones-bleues-okinawa-lile-ou-lon-vit-centenaire">l'île
                                    japonaise d'Okinawa</a>, révèle le secret d'une vie
                                longue et pleine de sens. Sur cette île, où de nombreux centenaires s'épanouissent,
                                trouver sa raison d'être, cultiver ses passions et créer de la valeur au quotidien est
                                ce qui nourrit le corps et l'esprit.
                            </p>

                            <div>
                                <svg width="150" height="200" xmlns="http://www.w3.org/2000/svg" xmlns:svg="http://www.w3.org/2000/svg" version="1.0">

                                    <g class="layer">
                                        <title>Layer 1</title>
                                        <g id="layer1" transform="translate(-0.298507 0) translate(-0.298507 0) translate(-0.298507 0) translate(0.298507 0) translate(0.298507 0) translate(0.298507 0) translate(0.298507 0) translate(0.298507 0) translate(8.35821 0.298507) translate(-11.6418 1.49254) matrix(1.20024 0 0 1.20024 -225.103 -61.899)">

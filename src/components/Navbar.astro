---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
  transparent?: boolean;
}

const { lang, transparent = true } = Astro.props;
const t = useTranslations(lang);

const homeUrl = lang === 'fr' ? '/' : `/${lang}/`;
const blogUrl = lang === 'fr' ? '/blog/' : `/${lang}/blog/`;
const switchLangUrl = lang === 'fr' ? '/en/' : '/';

const navClass = transparent 
  ? "fixed top-0 w-full z-[100] transition-all duration-300 transparent-mode"
  : "fixed top-0 w-full z-[100] transition-all duration-300 bg-bleu-crepuscule shadow-md";
---

<nav class={navClass} id="navbar" data-transparent={transparent.toString()}>
  <div class="container mx-auto px-6 py-4 flex justify-between items-center">
    <a href={homeUrl} class="nav-text text-2xl font-comfortaa font-bold drop-shadow-md transition-colors">
      be-ikigai
    </a>
    
    <div class="flex items-center gap-6 lg:gap-10">
      <a href={`${homeUrl}#accueil`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md hidden lg:block tracking-wide">
        {lang === 'fr' ? 'Accueil' : 'Home'}
      </a>
      <a href={`${homeUrl}#qui-suis-je`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md hidden lg:block tracking-wide">
        {lang === 'fr' ? 'À propos' : 'About'}
      </a>
      <a href={`${homeUrl}#solution`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md hidden lg:block tracking-wide">
        Services
      </a>
      <a href={blogUrl} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        Blog
      </a>
      <a href={`${homeUrl}#contact`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md hidden md:block tracking-wide">
        Contact
      </a>
    </div>
  </div>
</nav>

<script>
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    const isTransparent = navbar?.dataset.transparent === 'true';
    if (!isTransparent) return;

    if (window.scrollY > 50) {
      navbar?.classList.add('bg-bleu-crepuscule', 'shadow-md');
      navbar?.classList.remove('transparent-mode');
    } else {
      navbar?.classList.remove('bg-bleu-crepuscule', 'shadow-md');
      navbar?.classList.add('transparent-mode');
    }
  });
</script>

<style>
  .nav-text {
    color: white;
  }
  .nav-btn {
    color: white;
    background-color: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(12px);
  }
  .nav-btn:hover {
    background-color: rgba(255, 255, 255, 0.4);
  }

  .transparent-mode .nav-text {
    color: #2c3e50;
  }
  .transparent-mode .nav-btn {
    color: #2c3e50;
    background-color: rgba(44, 62, 80, 0.1);
    border-color: rgba(44, 62, 80, 0.2);
  }
  .transparent-mode .nav-btn:hover {
    background-color: rgba(44, 62, 80, 0.2);
  }
</style>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
  transparent?: boolean;
}

const { lang, transparent = true } = Astro.props;
const t = useTranslations(lang);

const homeUrl = lang === 'fr' ? '/' : `/${lang}/`;
const blogUrl = lang === 'fr' ? '/blog/' : `/${lang}/blog/`;
const pricingUrl = lang === 'fr' ? '/tarifs/' : `/${lang}/pricing/`;
const switchLangUrl = lang === 'fr' ? '/en/' : '/';

const navClass = transparent 
  ? "fixed top-0 w-full z-[100] transition-all duration-300 transparent-mode"
  : "fixed top-0 w-full z-[100] transition-all duration-300 bg-bleu-crepuscule shadow-md";
---

<nav class={navClass} id="navbar" data-transparent={transparent.toString()}>
  <div class="container mx-auto px-6 py-4 flex justify-between items-center relative">
    <a href={homeUrl} class="nav-text text-2xl font-comfortaa font-bold drop-shadow-md transition-colors z-[60] relative">
      be-ikigai
    </a>
    
    <!-- Mobile CTA + Hamburger -->
    <div class="lg:hidden flex items-center gap-2 z-[60] relative">
      <a
        href={pricingUrl}
        data-open-booking
        class="px-4 py-2 bg-[#9333ea] hover:bg-[#7e22ce] text-white text-sm font-comfortaa font-semibold rounded-full shadow-md transition-colors"
      >
        {lang === 'fr' ? 'Réserver' : 'Book'}
      </a>
    <button id="mobile-menu-btn" aria-label="Toggle Menu" class="flex items-center justify-center min-w-[44px] min-h-[44px] nav-text focus:outline-none transition-transform duration-300">
      <svg id="hamburger-icon" class="w-8 h-8 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg id="close-icon" class="w-8 h-8 hidden transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-6 lg:gap-10">
      <a href={`${homeUrl}#accueil`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        {lang === 'fr' ? 'Accueil' : 'Home'}
      </a>
      <a href={`${homeUrl}#qui-suis-je`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        {lang === 'fr' ? 'À propos' : 'About'}
      </a>
      <a href={`${homeUrl}#solution`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        Services
      </a>
      <a href={pricingUrl} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        {lang === 'fr' ? 'Tarifs' : 'Pricing'}
      </a>
      <a href={blogUrl} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        Blog
      </a>
      <a href={`${homeUrl}#contact`} class="nav-text font-comfortaa font-semibold hover:text-dore-serein transition-colors drop-shadow-md tracking-wide">
        Contact
      </a>
    </div>
  </div>

  <!-- Mobile Overlay Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-[#1A2A44]/95 backdrop-blur-md transform translate-x-full transition-transform duration-300 ease-in-out z-50 lg:hidden flex flex-col justify-center items-center">
    <div class="flex flex-col items-center gap-8 text-center pt-16 w-full px-6">
      <a href={`${homeUrl}#accueil`} class="mobile-link text-white text-2xl font-comfortaa font-semibold hover:text-dore-serein py-4 min-w-[48px] min-h-[48px] transition-colors w-full border-b border-white/10">
        {lang === 'fr' ? 'Accueil' : 'Home'}
      </a>
      <a href={`${homeUrl}#qui-suis-je`} class="mobile-link text-white text-2xl font-comfortaa font-semibold hover:text-dore-serein py-4 min-w-[48px] min-h-[48px] transition-colors w-full border-b border-white/10">
        {lang === 'fr' ? 'À propos' : 'About'}
      </a>
      <a href={`${homeUrl}#solution`} class="mobile-link text-white text-2xl font-comfortaa font-semibold hover:text-dore-serein py-4 min-w-[48px] min-h-[48px] transition-colors w-full border-b border-white/10">
        Services
      </a>
      <a href={pricingUrl} class="mobile-link text-white text-2xl font-comfortaa font-semibold hover:text-dore-serein py-4 min-w-[48px] min-h-[48px] transition-colors w-full border-b border-white/10">
        {lang === 'fr' ? 'Tarifs' : 'Pricing'}
      </a>
      <a href={blogUrl} class="mobile-link text-white text-2xl font-comfortaa font-semibold hover:text-dore-serein py-4 min-w-[48px] min-h-[48px] transition-colors w-full border-b border-white/10">
        Blog
      </a>
      <a href={`${homeUrl}#contact`} class="mobile-link text-white text-2xl font-comfortaa font-semibold hover:text-dore-serein py-4 min-w-[48px] min-h-[48px] transition-colors w-full border-b border-white/10">
        Contact
      </a>
    </div>
  </div>
</nav>

<script>
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    const isTransparent = navbar?.dataset.transparent === 'true';
    if (!isTransparent) return;

    if (window.scrollY > 50) {
      navbar?.classList.add('bg-bleu-crepuscule', 'shadow-md');
      navbar?.classList.remove('transparent-mode');
    } else {
      navbar?.classList.remove('bg-bleu-crepuscule', 'shadow-md');
      navbar?.classList.add('transparent-mode');
    }
  });

  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  let isMenuOpen = false;

  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('translate-x-full');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    }
  };

  mobileMenuBtn?.addEventListener('click', toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if(isMenuOpen) toggleMenu();
    });
  });
</script>

<style>
  .nav-text {
    color: white;
  }
  .nav-btn {
    color: white;
    background-color: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(12px);
  }
  .nav-btn:hover {
    background-color: rgba(255, 255, 255, 0.4);
  }

  .transparent-mode .nav-text {
    color: #2c3e50;
  }
  .transparent-mode .nav-btn {
    color: #2c3e50;
    background-color: rgba(26, 42, 68, 0.1);
    border-color: rgba(26, 42, 68, 0.2);
  }
  .transparent-mode .nav-btn:hover {
    background-color: rgba(26, 42, 68, 0.2);
  }
</style>

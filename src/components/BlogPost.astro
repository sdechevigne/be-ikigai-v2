---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { render } from 'astro:content';
import '../styles/blog-retro.css';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const formattedDate = post.data.publishedAt 
    ? new Date(post.data.publishedAt).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' })
    : null;
    
const category = post.data.category || (lang === 'en' ? 'General' : 'Général');
const author = post.data.author || 'Pierre-Louis';

const readingTime = post.data.readingTime ?? Math.max(1, Math.round((post.body?.split(/\s+/).length ?? 0) / 200));
---

<Layout 
    title={`${post.data.title} | be-ikigai`} 
    description={post.data.description || ''} 
    keywords={post.data.seoKeywords || ''} 
    lang={lang}
    type="article"
    image={post.data.image ? `https://be-ikigai.com${post.data.image}` : undefined}
>
    <!-- BreadcrumbList for blog posts -->
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": lang === 'en' ? "Home" : "Accueil",
                "item": lang === 'en' ? "https://be-ikigai.com/en/" : "https://be-ikigai.com/"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Blog",
                "item": lang === 'en' ? "https://be-ikigai.com/en/blog/" : "https://be-ikigai.com/blog/"
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": category,
                "item": lang === 'en' ? `https://be-ikigai.com/en/blog/` : `https://be-ikigai.com/blog/`
            },
            {
                "@type": "ListItem",
                "position": 4,
                "name": post.data.title,
                "item": `https://be-ikigai.com${Astro.url.pathname}`
            }
        ]
    }, null, 2)} />
    <!-- Article Schema for blog posts -->
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": post.data.title,
        "description": post.data.description,
        "image": post.data.image ? `https://be-ikigai.com${post.data.image}` : "https://be-ikigai.com/assets/img/logo_fullhd.png",
        "datePublished": post.data.publishedAt ? new Date(post.data.publishedAt).toISOString() : undefined,
        "author": {
            "@type": "Person",
            "name": author,
            "url": "https://be-ikigai.com"
        },
        "publisher": {
            "@type": "Organization",
            "name": "be-ikigai",
            "logo": {
                "@type": "ImageObject",
                "url": "https://be-ikigai.com/assets/img/logo_fullhd.png"
            }
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": `https://be-ikigai.com${Astro.url.pathname}`
        },
        "inLanguage": lang === 'en' ? "en-US" : "fr-FR",
        "articleSection": category
    }, null, 2)} />
    {post.data.faq && post.data.faq.length > 0 && (
        <script slot="head" type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": post.data.faq.map(item => ({
                "@type": "Question",
                "name": item.question,
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": item.answer || ""
                }
            }))
        }, null, 2)} />
    )}
    <Navbar lang={lang} transparent={false} />
    
    <main class="pt-14">
        <section class="blog-hero-section pt-28 lg:pt-32">
            <div class="wrap px-6" style="max-width: 1200px; margin: 0 auto;">
                <div class="blog-hero" style={`background-image: url('${post.data.image ?? '/assets/img/hero.webp'}')`}>
                    <div class="blog-hero-overlay"></div>
                    <div class="blog-hero-content">
                        <nav aria-label="Fil d'Ariane" style="width:100%;">
                            <ol class="breadcrumb-list-hero" style="justify-content:center;">
                                <li><a href="/">{lang === 'en' ? 'Home' : 'Accueil'}</a></li>
                                <li>
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                    <a href={lang === 'fr' ? '/blog' : `/${lang}/blog`}>Blog</a>
                                </li>
                                <li>
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                    <span style="color:#fff;">{category}</span>
                                </li>
                            </ol>
                        </nav>
                        <h1 class="blog-hero-h1" style="font-size:clamp(28px,4vw,48px); letter-spacing:-1.5px;">{post.data.title}</h1>
                        <div class="article-meta" style="justify-content:center;">
                            <div class="article-author">
                                <div class="author-avatar">
                                    <img src={`https://ui-avatars.com/api/?name=${author}&background=ffd700&color=2c3e50`} alt={author} width="40" height="40" />
                                </div>
                                <span class="author-name">{author}</span>
                            </div>
                            {formattedDate && (
                                <>
                                    <div class="meta-sep"></div>
                                    <span class="meta-item">{formattedDate}</span>
                                </>
                            )}
                            <div class="meta-sep"></div>
                            <span class="meta-item">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                {readingTime} min {lang === 'en' ? 'read' : 'de lecture'}
                            </span>
                            <div class="meta-sep"></div>
                            <span class="article-cat-badge" style="margin-bottom:0;">{category}</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="article-wrap">
            <div class="wrap" style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
                <div class="article-layout">
                    <!-- MAIN CONTENT -->
                    <div class="article-main">
                        {post.data.summary && post.data.summary.length > 0 && (
                            <div class="article-summary">
                                <div class="summary-label">{lang === 'en' ? 'In brief' : 'En bref'}</div>
                                <ul class="summary-bullets">
                                    {post.data.summary.map(item => <li>{item}</li>)}
                                </ul>
                            </div>
                        )}
                        
                        <article class="article-content" id="article-content">
                            <Content />
                        </article>

                        {post.data.faq && post.data.faq.length > 0 && (
                            <section class="article-faq">
                                <h2>{lang === 'en' ? 'Frequently asked questions' : 'Questions fréquentes'}</h2>
                                <div class="faq-list">
                                    {post.data.faq.map(item => (
                                        <details class="faq-item">
                                            <summary class="faq-question">
                                                <span>{item.question}</span>
                                                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                            </summary>
                                            <p class="faq-answer">{item.answer}</p>
                                        </details>
                                    ))}
                                </div>
                            </section>
                        )}
                    </div>

                    <!-- SIDEBAR -->
                    <aside class="article-sidebar">
                        <div class="sidebar-sticky">
                            <div class="toc-block" id="toc-container" style="display: none;">
                                <div class="toc-title">{lang === 'en' ? 'In this article' : 'Dans cet article'}</div>
                                <nav class="toc" id="toc" aria-label="Table des matières">
                                    <!-- Generated client-side -->
                                </nav>
                            </div>
                            
                            <div class="sidebar-cta w-full">
                                <h4 class="sidebar-cta-title">{lang === 'en' ? 'Find your Ikigai' : 'Trouvez votre Ikigai'}</h4>
                                <p class="sidebar-cta-text">{lang === 'en' ? 'Ready to give meaning to your professional life?' : 'Prêt à redonner du sens à votre vie professionnelle ?'}</p>
                                <a href="/#contact" class="inline-block bg-dore-serein text-bleu-crepuscule font-bold py-3 px-6 rounded-xl hover:opacity-90 transition w-full">{lang === 'en' ? 'Contact us' : 'Prendre un premier RDV gratuit'}</a>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
        
    </main>
    
    <script type="module">
        document.addEventListener("DOMContentLoaded", () => {
            const content = document.getElementById("article-content");
            if (content) {
                content.querySelectorAll("table").forEach(table => {
                    if (!table.parentElement?.classList.contains("table-wrapper")) {
                        const wrapper = document.createElement("div");
                        wrapper.className = "table-wrapper";
                        table.parentNode?.insertBefore(wrapper, table);
                        wrapper.appendChild(table);
                    }
                });
            }

            const toc = document.getElementById("toc");
            const tocContainer = document.getElementById("toc-container");
            if (!toc || !content) return;
            
            const headings = content.querySelectorAll("h2");
            if (headings.length === 0) return;
            
            if (tocContainer) tocContainer.style.display = 'block';
            
            headings.forEach((h, i) => { if(!h.id) h.id = `heading-${i}`; });
            
            const frag = document.createDocumentFragment();
            const links = [];
            
            headings.forEach(h => {
                const a = document.createElement("a");
                a.href = `#${h.id}`;
                a.textContent = h.textContent || "";
                links.push(a);
                frag.appendChild(a);
            });
            
            toc.appendChild(frag);
            
            const obs = new IntersectionObserver(entries => {
                entries.forEach(e => {
                    if(e.isIntersecting) {
                        links.forEach(l => l.classList.remove("active"));
                        const link = links.find(l => l.getAttribute("href") === `#${e.target.id}`);
                        if(link) link.classList.add("active");
                    }
                });
            }, { rootMargin: "-20% 0px -70% 0px" });
            
            headings.forEach(h => obs.observe(h));
        });
    </script>
    <Footer lang={lang} />
</Layout>

---
import '../styles/global.css';
import { Agentation } from 'agentation';

interface Props {
	title: string;
	description: string;
    lang?: string;
    keywords?: string;
    image?: string;
    type?: string;
    canonicalPath?: string;
}

const { 
    title, 
    description, 
    lang = "fr", 
    keywords,
    image = "https://be-ikigai.com/assets/img/logo_fullhd.png",
    type = "website",
    canonicalPath
} = Astro.props;

const baseUrl = "https://be-ikigai.com";

// Build canonical URL
const currentPath = canonicalPath || Astro.url.pathname;
const canonicalUrl = `${baseUrl}${currentPath}`;

// Build alternate URLs for hreflang
const pathWithoutLang = currentPath.replace(/^\/en\/?/, '/');
const frUrl = `${baseUrl}${pathWithoutLang}`;
const enUrl = `${baseUrl}/en${pathWithoutLang === '/' ? '/' : pathWithoutLang}`;

// Default keywords per language
const defaultKeywordsFr = "ikigai, raison d'être, coaching personnel, philosophie japonaise, Okinawa, passion mission vocation, coaching ikigai, développement personnel, trouver sa voie, sens de la vie, coaching Paris, Pierre-Louis coach";
const defaultKeywordsEn = "ikigai, reason for being, personal coaching, Japanese philosophy, Okinawa, passion mission vocation, ikigai coaching, personal development, find your path, meaning of life, life coaching, Pierre-Louis coach";
const resolvedKeywords = keywords || (lang === 'en' ? defaultKeywordsEn : defaultKeywordsFr);

// OG locale
const ogLocale = lang === 'en' ? 'en_US' : 'fr_FR';
const ogLocaleAlternate = lang === 'en' ? 'fr_FR' : 'en_US';

// Site name
const siteName = "be-ikigai";
---

<!DOCTYPE html>
<html lang={lang}>
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="keywords" content={resolvedKeywords}>
	<meta name="author" content="Pierre-Louis">
	<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
	
	<!-- Canonical & Hreflang for bilingual SEO -->
	<link rel="canonical" href={canonicalUrl} />
	<link rel="alternate" hreflang="fr" href={frUrl} />
	<link rel="alternate" hreflang="en" href={enUrl} />
	<link rel="alternate" hreflang="x-default" href={frUrl} />

	<!-- Favicon -->
	<link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="apple-touch-icon" href="/assets/img/favicon.ico" />

	<!-- Fonts (non-blocking) -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
	<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
	<noscript><link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&display=swap" rel="stylesheet"></noscript>
	
	<!-- Open Graph -->
	<meta property="og:type" content={type}>
	<meta property="og:url" content={canonicalUrl}>
	<meta property="og:title" content={title}>
	<meta property="og:description" content={description}>
	<meta property="og:image" content={image}>
	<meta property="og:image:width" content="1200">
	<meta property="og:image:height" content="630">
	<meta property="og:locale" content={ogLocale}>
	<meta property="og:locale:alternate" content={ogLocaleAlternate}>
	<meta property="og:site_name" content={siteName}>
	
	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:site" content="@be_ikigai_com">
	<meta name="twitter:title" content={title}>
	<meta name="twitter:description" content={description}>
	<meta name="twitter:image" content={image}>

	<!-- Geo targeting -->
	<meta name="geo.region" content="FR">
	<meta name="geo.placename" content="Paris">
	<meta name="geo.position" content="48.855464;2.324940">
	<meta name="ICBM" content="48.855464, 2.324940">

	<!-- Schema.org JSON-LD: LocalBusiness -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "LocalBusiness",
		"name": lang === 'en' ? "be-ikigai - Ikigai Coaching by Pierre-Louis" : "be-ikigai - Coaching Ikigai par Pierre-Louis",
		"description": lang === 'en'
			? "Discover your Ikigai, your reason for being, through authentic and caring coaching. Free discovery session."
			: "Découvrez votre Ikigai, votre raison d'être, grâce à un coaching authentique et bienveillant. Séance découverte offerte.",
		"url": lang === 'en' ? "https://be-ikigai.com/en/" : "https://be-ikigai.com",
		"image": "https://be-ikigai.com/assets/img/logo_fullhd.png",
		"email": "pierrelouis@be-ikigai.com",
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "Rue du Bac",
			"addressLocality": "Paris",
			"addressRegion": "Ile de France",
			"postalCode": "75007",
			"addressCountry": "FR"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 48.855464146067725,
			"longitude": 2.324939579215864
		},
		"openingHoursSpecification": [
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
				"opens": "09:00",
				"closes": "18:00"
			}
		],
		"priceRange": "$$",
		"areaServed": [
			{ "@type": "Country", "name": "FR" },
			{ "@type": "Country", "name": "BE" },
			{ "@type": "Country", "name": "CH" },
			{ "@type": "Country", "name": "LU" },
			{ "@type": "Country", "name": "NL" }
		],
		"founder": {
			"@type": "Person",
			"name": "Pierre-Louis",
			"jobTitle": lang === 'en' ? "Certified Ikigai Coach" : "Coach Ikigai Certifié",
			"image": "https://be-ikigai.com/assets/img/pl.webp",
			"email": "pierrelouis@be-ikigai.com",
			"sameAs": [
				"https://x.com/be_ikigai_com",
				"https://www.tiktok.com/@be_ikigai",
				"https://www.youtube.com/@beikigai"
			]
		},
		"sameAs": [
			"https://x.com/be_ikigai_com",
			"https://www.tiktok.com/@be_ikigai",
			"https://www.youtube.com/@beikigai",
			"https://musicbrainz.org/artist/c3eb4b07-4b1a-4b7d-b566-65c826e92fce"
		],
		"hasOfferCatalog": {
			"@type": "OfferCatalog",
			"name": lang === 'en' ? "Ikigai coaching services" : "Services de coaching Ikigai",
			"itemListElement": [
				{
					"@type": "Offer",
					"itemOffered": {
						"@type": "Service",
						"name": lang === 'en' ? "Ikigai Discovery Session" : "Séance découverte Ikigai",
						"description": lang === 'en' ? "30 free minutes to explore your Ikigai" : "30 minutes gratuites pour explorer votre Ikigai"
					},
					"price": "0",
					"priceCurrency": "EUR",
					"availability": "https://schema.org/InStock"
				},
				{
					"@type": "Offer",
					"itemOffered": {
						"@type": "Service",
						"name": lang === 'en' ? "Full Ikigai Program" : "Programme Ikigai Complet",
						"description": lang === 'en' ? "Complete personalized coaching" : "Coaching personnalisé complet"
					},
					"price": "300",
					"priceCurrency": "EUR"
				}
			]
		},
		"review": [
			{
				"@type": "Review",
				"reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
				"author": { "@type": "Person", "name": "Tristan" },
				"datePublished": "2025-09-15",
				"reviewBody": lang === 'en'
					? "Pierre-Louis, in a very professional manner, quickly identifies your habits, desires, and way of functioning to incorporate all these elements into a professional framework and offer excellent avenues for reflection for future positions or sectors of activity."
					: "Pierre-Louis d'une manière très professionnelle arrive à très vite cerner vos habitudes, vos désirs, votre manière de fonctionner pour introduire tous ces éléments dans le cadre professionnel et vous proposez d'excellentes pistes de réflexions pour de futurs postes ou secteurs d'activités.",
				"name": "Tristan - Témoignage Ikigai"
			},
			{
				"@type": "Review",
				"reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
				"author": { "@type": "Person", "name": "Hugues" },
				"datePublished": "2025-10-20",
				"reviewBody": lang === 'en'
					? "A month after our session, Pierre-Louis's questions continue to resonate and help me make the right choices in my career."
					: "Un mois après notre séance, les questions de Pierre-Louis continuent de résonner et m'aident à faire les bons choix dans mon parcours professionnel.",
				"name": lang === 'en' ? "Hugues - Personalized coaching" : "Hugues - Coaching personnalisé"
			},
			{
				"@type": "Review",
				"reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
				"author": { "@type": "Person", "name": "Jérémie" },
				"datePublished": "2025-07-10",
				"reviewBody": lang === 'en'
					? "More than just a conversation, Pierre-Louis offered me an introspective journey. This honest and sincere discussion gave me confidence and allowed me to uncover answers buried within me that had never surfaced before."
					: "Bien plus qu'un échange, Pierre-Louis m'a offert un voyage introspectif. En effet cette discution honnête et sincère m'a mis en confiance et m'a permis de donner des réponses enfouie en moi mais qui ne m'était jamais apparu.",
				"name": lang === 'en' ? "Jérémie - Ikigai Discovery" : "Jérémie - Découverte Ikigai"
			}
		],
		"aggregateRating": {
			"@type": "AggregateRating",
			"ratingValue": "5.0",
			"reviewCount": "3",
			"bestRating": "5"
		}
	}, null, 2)} />

	<!-- Schema.org JSON-LD: WebSite with SearchAction -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": siteName,
		"url": baseUrl,
		"inLanguage": [lang === 'en' ? "en-US" : "fr-FR"],
		"description": description,
		"publisher": {
			"@type": "Organization",
			"name": siteName,
			"url": baseUrl,
			"logo": {
				"@type": "ImageObject",
				"url": `${baseUrl}/assets/img/logo_fullhd.png`
			}
		}
	}, null, 2)} />

	<!-- Schema.org JSON-LD: BreadcrumbList -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": lang === 'en' ? "Home" : "Accueil",
				"item": lang === 'en' ? `${baseUrl}/en/` : baseUrl
			}
		]
	}, null, 2)} />

	<slot name="head" />
</head>
<body class="overflow-x-hidden bg-blanc-coton text-bleu-crepuscule">
	<slot />
    <script>
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => {
            observer.observe(el);
        });

        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        window.addEventListener('load', () => {
            document.querySelector('.fade-in')?.classList.add('visible');
        });
    </script>
    {import.meta.env.DEV && <Agentation client:only="react" />}
</body>
</html>

---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { slugifyCategory } from '../../../i18n/utils';
import BlogList from '../../../components/BlogList.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const frPublished = allPosts.filter(p => p.data.lang === 'fr' && p.data.status === 'published');

  const categoryMap = new Map<string, CollectionEntry<'blog'>[]>();
  for (const post of frPublished) {
    const cat = post.data.category;
    if (!cat) continue;
    if (!categoryMap.has(cat)) categoryMap.set(cat, []);
    categoryMap.get(cat)!.push(post);
  }

  return [...categoryMap.entries()].map(([cat, catPosts]) => ({
    params: { category: slugifyCategory(cat, 'fr') },
    props: {
      categoryName: cat,
      posts: catPosts.sort((a, b) => (b.data.publishedAt?.valueOf() ?? 0) - (a.data.publishedAt?.valueOf() ?? 0)),
    },
  }));
}

const { categoryName, posts } = Astro.props;
---

<BlogList posts={posts} categoryFilter={categoryName} />

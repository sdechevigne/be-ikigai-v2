---
import { getCollection } from "astro:content";

import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === lang && data.status === 'published';
});
const recentPosts = allPosts.sort((a, b) => {
    const dateA = new Date(a.data.publishedAt || 0).valueOf();
    const dateB = new Date(b.data.publishedAt || 0).valueOf();
    return dateB - dateA;
}).slice(0, 3);
---

<Layout 
    title={lang === 'en' 
        ? "Ikigai Coaching: Find Your Reason for Being | be-ikigai Paris" 
        : "Coaching Ikigai : Trouvez Votre Raison d'Être | be-ikigai Paris"
    } 
    description={lang === 'en'
        ? "Discover your Ikigai, the Japanese philosophy for a fulfilled life. Free 30-min discovery session with Pierre-Louis, Certified Ikigai Coach in Paris."
        : "Découvrez votre Ikigai, la philosophie japonaise pour une vie épanouie. Séance découverte gratuite de 30 min avec Pierre-Louis, Coach Ikigai Certifié à Paris."
    }
    lang={lang}
    keywords={lang === 'en'
        ? "ikigai coaching, find your purpose, reason for being, Japanese philosophy, life coaching Paris, personal development, Pierre-Louis coach, Okinawa, career coaching, meaning of life"
        : "coaching ikigai, trouver sa raison d'être, philosophie japonaise, coaching Paris, développement personnel, Pierre-Louis coach, Okinawa, coaching de vie, sens de la vie, reconversion professionnelle"
    }
>

    <Navbar lang={lang} />

    <!-- Google Tag Manager (noscript) -->
    

    <!-- Bouton sticky avec animation wave -->
    <a href="https://music.be-ikigai.com" class="fixed bottom-4 right-4 bg-gradient-to-r bg-button-degrade text-white rounded-full p-4 shadow-lg transition-all duration-300 hover:scale-110 group z-10">
        <div class="flex items-center gap-3">
            <div class="flex items-center justify-center gap-1 h-10 w-12">
                <div class="bar1 w-1.5 bg-white rounded-full"></div>
                <div class="bar2 w-1.5 bg-white rounded-full"></div>
                <div class="bar3 w-1.5 bg-white rounded-full"></div>
                <div class="bar4 w-1.5 bg-white rounded-full"></div>
                <div class="bar5 w-1.5 bg-white rounded-full"></div>
            </div>
            <span class="font-semibold font-comfortaa text-lg">ikigai's music</span>
        </div>
    </a>

    <!-- Section 1: Bannière d'Accueil -->
    <section class="hero-bg min-h-screen flex items-center justify-center relative" id="accueil">
        <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/60 md:from-transparent md:via-transparent md:to-black/20">
        </div>
        <div class="container mx-auto px-6 text-center relative z-10">
            <div class="max-w-4xl mx-auto fade-in">
                <h1 class="text-3xl md:text-5xl lg:text-6xl font-comfortaa text-white mb-6 leading-tight 
                       drop-shadow-[0_4px_12px_rgba(0,0,0,0.8)] md:drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]
                       font-bold md:font-normal">
                    {t('hero.title')}</h1>
                <p class="text-xl md:text-2xl text-white/90 mb-12 drop-shadow-[0_4px_12px_rgba(0,0,0,0.8)] md:drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">
                    {t('hero.subtitle')}
                </p>
                <a href="#contact" class="btn-secondary inline-block px-8 py-4 text-white font-comfortaa rounded-full text-lg shadow-lg hover:shadow-xl transition-all duration-300">
                    {t('btn.reserver')} <span class="hidden md:inline-block">{t('hero.discovery')}</span>
                </a>
            </div>
        </div>
    </section>

    <!-- Section 2: Le Point de Douleur -->
    <section class="pain-bg py-14 lg:py-32" id="douleur">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto text-center">
                <div class="fade-in mb-24">
                    <h2 class="text-3xl md:text-5xl font-comfortaa text-white mb-24 italic"> <small class="text-xl md:text-2xl">Ce dialogue intérieur, de plus en plus présent, qui vous
                            dit:</small> <svg class="text-4xl text-white-600" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" width="1em" height="1em" preserveAspectRatio="xMidYMid meet" viewBox="0 0 24 24">
                            <path fill="currentColor" d="M6.5 10c-.223 0-.437.034-.65.065c.069-.232.14-.468.254-.68c.114-.308.292-.575.469-.844c.148-.291.409-.488.601-.737c.201-.242.475-.403.692-.604c.213-.21.492-.315.714-.463c.232-.133.434-.28.65-.35l.539-.222l.474-.197l-.485-1.938l-.597.144c-.191.048-.424.104-.689.171c-.271.05-.56.187-.882.312c-.318.142-.686.238-1.028.466c-.344.218-.741.4-1.091.692c-.339.301-.748.562-1.05.945c-.33.358-.656.734-.909 1.162c-.293.408-.492.856-.702 1.299c-.19.443-.343.896-.468 1.336c-.237.882-.343 1.72-.384 2.437c-.034.718-.014 1.315.028 1.747c.015.204.043.402.063.539l.025.168l.026-.006A4.5 4.5 0 1 0 6.5 10zm11 0c-.223 0-.437.034-.65.065c.069-.232.14-.468.254-.68c.114-.308.292-.575.469-.844c.148-.291.409-.488.601-.737c.201-.242.475-.403.692-.604c.213-.21.492-.315.714-.463c.232-.133.434-.28.65-.35l.539-.222l.474-.197l-.485-1.938l-.597.144c-.191.048-.424.104-.689.171c-.271.05-.56.187-.882.312c-.317.143-.686.238-1.028.467c-.344.218-.741.4-1.091.692c-.339.301-.748.562-1.05.944c-.33.358-.656.734-.909 1.162c-.293.408-.492.856-.702 1.299c-.19.443-.343.896-.468 1.336c-.237.882-.343 1.72-.384 2.437c-.034.718-.014 1.315.028 1.747c.015.204.043.402.063.539l.025.168l.026-.006A4.5 4.5 0 1 0 17.5 10z"></path>
                        </svg> Allez, courage... Si je ne change pas {t('contact.p2_part2')}, je vais <span class="text-dore-serein">couler</span>.
                    </h2>
                    <div class="mx-auto max-w-screen-xl px-4 md:px-8">
                        <div class="grid gap-8 md:grid-cols-2 lg:gap-12">
                            <div class="lg:flex lg:flex-col ">
                                <div class="text-lg md:text-xl text-white/90 space-y-6">
                                    <p>Ce sentiment de cocher toutes les cases d'une "vie réussie", mais de <span class="text-dore-serein">ressentir un vide profond</span> qui s'agrandit
                                        doucement.</p>
                                    <p>Cette impression de <span class="text-dore-serein">courir dans une roue de
                                            hamster</span>, de vivre en pilotage semi-automatique sans vraiment savoir
                                        ce qui se passe.</p>
                                    <p>Le dimanche soir où l'idée du lundi nous pèse, ce sentiment diffus de <span class="text-dore-serein">ne pas être pleinement vivant</span>, cette
                                        sensation qui commence à prendre de la place entre qui l'on est et qui on doit
                                        être pour être bien.</p>
                                </div>
                            </div>

                            <div class="h-64 overflow-hidden rounded-lg shadow-lg md:h-auto">

                                <img loading="lazy" class="h-full w-full object-cover object-center" src="/assets/img/pain.webp" alt="Une personne à la croisée de plusieurs chemins dans une forêt dense et brumeuse" width="600" height="400">
                            </div>

                        </div>
                    </div>
                </div>

                <div class="fade-in mb-24">
                    <h3 class="text-xl md:text-2xl font-comfortaa text-blanc-coton">{t('pain.whether')}</h3>
                    <div class="mt-8 mb-8 flex flex-col items-center justify-center divide-y divide-gray-300 sm:flex-row sm:divide-x sm:divide-y-0">
                        <div class="flex flex-col items-center space-x-2 px-4 py-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-dore-serein mb-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 0 1-1.161.886l-.143.048a1.107 1.107 0 0 0-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 0 1-1.652.928l-.679-.906a1.125 1.125 0 0 0-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 0 0-8.862 12.872M12.75 3.031a9 9 0 0 1 6.69 14.036m0 0-.177-.529A2.25 2.25 0 0 0 17.128 15H16.5l-.324-.324a1.453 1.453 0 0 0-2.328.377l-.036.073a1.586 1.586 0 0 1-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438c.08.474.49.821.97.821.846 0 1.598.542 1.865 1.345l.215.643m5.276-3.67a9.012 9.012 0 0 1-5.276 3.67m0 0a9 9 0 0 1-10.275-4.835M15.75 9c0 .896-.393 1.7-1.016 2.25"></path>
                            </svg>
                            <p class="text-lg md:text-xl text-blanc-coton">Une personne qui se sent de plus en plus
                                seule face à ce monde
                                qui change.</p>
                        </div>
                        <div class="flex flex-col items-center space-x-2 px-4 py-4">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-dore-serein mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"></path>
                            </svg>
                            <p class="text-lg md:text-xl text-blanc-coton">Un parent souhaitant mieux comprendre son
                                enfant et créer une relation durable</p>
                        </div>
                        <div class="flex flex-col items-center space-x-2 px-4 py-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-dore-serein mb-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z"></path>
                            </svg>
                            <p class="text-lg md:text-xl text-blanc-coton">Un enfant qui souhaite se connaitre
                                rapidement et trouver sa voie.</p>
                        </div>
                    </div>
                    <h3 class="text-xl md:text-2xl font-comfortaa text-white mb-12">...ou simplement en quête de sens
                        dans le brouillard du quotidien...</h3>
                </div>
                <div class="fade-in ">
                    <p class="text-xl md:text-2xl text-blanc-coton font-medium">
                        Si ces mots résonnent en vous, ce n'est pas un hasard. C'est un appel intérieur qui vous signale
                        qu'il est temps de changer. <span class="text-dore-serein ">Cultivons ensemble l'envie d'avoir
                            envie</span>.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 3: La Solution & la Transformation -->
    <section class="solution-bg py-14 lg:py-32" id="solution">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-16 fade-in">
                    <h2 class="text-3xl md:text-5xl font-comfortaa text-bleu-crepuscule mb-8 md:mb-16">
                        La solution n'est pas à l'extérieur. Elle est en vous depuis toujours : <span class="font-comfortaa text-[#9333ea] font-bold">c'est votre Ikigai.</span>
                    </h2>

                    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start text-left md:text-left">
                        <div class="text-lg md:text-xl text-gray-600 space-y-6">
                            <p class="mb-4">Toutes les réponses que vous cherchez, cette énergie, cette évidence...
                                elles ne
                                sont pas à l'extérieur. Elles sont en vous, c'est un trésor précieux, trouvons le
                                ensemble en
                                discutant. Cette philosophie japonaise est bien plus qu'un concept, <span class="text-[#9333ea] font-bold">c'est
                                    votre nouvelle "raison d'être"</span>.</p>

                            <p class="mb-4">Trouver son Ikigai, c'est partir à la découverte de qui vous êtes vraiment
                                pour
                                <span class="text-bleu-crepuscule font-bold">{t('solution.p3_part2')}</span> entre votre passion,
                                vos
                                talents, et ce que vous apportez au monde.
                            </p>
                        </div>

                        <div class="h-64 md:h-80 overflow-hidden rounded-lg shadow-lg">
                            <img loading="lazy" class="h-full w-full object-cover object-center" src="/assets/img/lumiere.webp" alt="Un magnifique sentier baigné de soleil qui serpente dans une forêt calme et luxuriante." width="600" height="400">
                        </div>
                    </div>

                    <div class="text-lg md:text-xl text-gray-600 space-y-6 mt-8 text-left md:text-left">
                        <p class="mb-4">Mon accompagnement n'est pas une simple discussion, elle ne suivra pas un
                            processus
                            formel et rigide. Ce que je vous propose est bien plus authentique : <span class="text-[#9333ea] font-bold">une relation de confiance, un espace d'échange profond et
                                honnête.</span></p>

                        <p class="mb-4">Dans cet espace, je serai celui qui tient la lanterne pour éclairer votre chemin
                            intérieur avec bienveillance. Celui qui vous écoute vraiment, pour vous aider à entendre ce
                            que
                            votre cœur essaie de vous dire. C'est dans la qualité de cet échange que <span class="text-bleu-crepuscule font-bold">{t('solution.p5_part2')}</span>.</p>
                    </div>
                </div>


                <div class="bg-white rounded-3xl shadow-lg p-8 md:p-12 fade-in">
                    <h3 class="text-2xl md:text-3xl font-comfortaa text-[#9333ea] font-bold text-center mb-8">
                        {t('after.title')}
                    </h3>
                    <div class="grid md:grid-cols-1 gap-6">
                        <div class="flex items-start space-x-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-[#9333ea] font-bold">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
                            </svg>

                            <p class="text-gray-700 text-md">Vous vous levez le matin avec une énergie nouvelle et
                                l'évidence d'aimer votre vie.</p>
                        </div>
                        <div class="flex items-start space-x-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-[#9333ea] font-bold">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
                            </svg>
                            <p class="text-gray-700 text-md"> Vos choix deviennent clairs, fluides et alignés avec qui
                                vous êtes.</p>
                        </div>
                        <div class="flex items-start space-x-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-[#9333ea] font-bold">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
                            </svg>
                            <p class="text-gray-700 text-md">Votre vie pro et perso ne sont plus en conflit et se
                                nourrissent l'une avec l'autre.
                            </p>
                        </div>
                        <div class="flex items-start space-x-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-[#9333ea] font-bold">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
                            </svg>
                            <p class="text-gray-700 text-md">Vous ressentez un sentiment de paix,
                                d'accomplissement et de légitimité, {t('contact.p2_part2')} chaque jour a un sens.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-white py-14 lg:py-32">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-16 fade-in">
                    <svg class="text-[#9333ea] font-bold absolute right-5 bottom-6 text-7xl" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" width="1em" height="1em" preserveAspectRatio="xMidYMid meet" viewBox="0 0 24 24">
                        <path fill="currentColor" d="M6.5 10c-.223 0-.437.034-.65.065c.069-.232.14-.468.254-.68c.114-.308.292-.575.469-.844c.148-.291.409-.488.601-.737c.201-.242.475-.403.692-.604c.213-.21.492-.315.714-.463c.232-.133.434-.28.65-.35l.539-.222l.474-.197l-.485-1.938l-.597.144c-.191.048-.424.104-.689.171c-.271.05-.56.187-.882.312c-.318.142-.686.238-1.028.466c-.344.218-.741.4-1.091.692c-.339.301-.748.562-1.05.945c-.33.358-.656.734-.909 1.162c-.293.408-.492.856-.702 1.299c-.19.443-.343.896-.468 1.336c-.237.882-.343 1.72-.384 2.437c-.034.718-.014 1.315.028 1.747c.015.204.043.402.063.539l.025.168l.026-.006A4.5 4.5 0 1 0 6.5 10zm11 0c-.223 0-.437.034-.65.065c.069-.232.14-.468.254-.68c.114-.308.292-.575.469-.844c.148-.291.409-.488.601-.737c.201-.242.475-.403.692-.604c.213-.21.492-.315.714-.463c.232-.133.434-.28.65-.35l.539-.222l.474-.197l-.485-1.938l-.597.144c-.191.048-.424.104-.689.171c-.271.05-.56.187-.882.312c-.317.143-.686.238-1.028.467c-.344.218-.741.4-1.091.692c-.339.301-.748.562-1.05.944c-.33.358-.656.734-.909 1.162c-.293.408-.492.856-.702 1.299c-.19.443-.343.896-.468 1.336c-.237.882-.343 1.72-.384 2.437c-.034.718-.014 1.315.028 1.747c.015.204.043.402.063.539l.025.168l.026-.006A4.5 4.5 0 1 0 17.5 10z"></path>
                    </svg>
                    <div class="lg:py- flex flex-1 flex-col justify-between p-6 lg:px-7">
                        <div class="flex-1">
                            <blockquote class="mt-4 flex-1">
                                <h3 class="text-4xl text-gray-700 font-comfortaa">
                                    Un mois après notre séance, les questions de Pierre-Louis continuent de résonner et
                                    m’aident à faire les bons choix dans mon parcours professionnel.
                                </h3>
                            </blockquote>
                        </div>

                        <div class="mt-8 flex tracking-wide justify-center">
                            <p class="font-bold text-[#9333ea] font-bold">Hugues</p>
                            <p class="ml-3 text-gray-700">septembre 2025</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

    <GoogleReviews lang={lang} />

    <!-- Nouvelle Section Blog -->
    <section class="py-14 lg:py-24 bg-white">
        <div class="container mx-auto px-6 max-w-[1200px]">
            <div class="text-center fade-in mb-16">
                <h2 class="text-3xl md:text-5xl font-comfortaa text-[#2c3e50] mb-8 font-bold">
                    {lang === 'en' ? 'Latest from our blog' : 'Les derniers articles du blog'}
                </h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 fade-in">
                {recentPosts.length > 0 ? recentPosts.map((post) => {
                    const cat = post.data.category || (lang === 'fr' ? 'Général' : 'General');
                    const bgImg = post.data.image ? post.data.image : null;
                    const dateStr = post.data.publishedAt ? new Date(post.data.publishedAt).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
                    
                    return (
                        <a href={lang === 'fr' ? `/blog/${post.id}` : `/${lang}/blog/${post.id}`} class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col h-full border border-gray-100">
                            <div class="h-56 relative overflow-hidden bg-gray-100 flex-shrink-0">
                                {bgImg ? (
                                    <img src={bgImg} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="400" height="224" />
                                ) : (
                                    <div class="w-full h-full bg-gradient-to-br from-beige-chaleureux to-white flex items-center justify-center text-dore-serein">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14" />
                                        </svg>
                                    </div>
                                )}
                            </div>
                            <div class="p-8 flex flex-col flex-grow">
                                <div class="text-[#ffd700] text-xs font-bold uppercase tracking-wider mb-3">
